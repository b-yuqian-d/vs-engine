{
  "name": "vscode-automation",
  "version": "1.71.0",
  "description": "VS Code UI automation driver",
  "author": {
    "name": "Microsoft Corporation"
  },
  "license": "MIT",
  "main": "./out/index.js",
  "private": true,
  "scripts": {
    "compile": "pnpm run copy-driver-definition && node ../../node_modules/typescript/bin/tsc",
    "watch": "pnpm run --parallel '/watch-driver-definition|watch-tsc/'",
    "watch-tsc": "node ../../node_modules/typescript/bin/tsc --watch --preserveWatchOutput",
    "copy-driver-definition": "node tools/copy-driver-definition.js",
    "watch-driver-definition": "nodemon --watch ../../src/vs/workbench/services/driver/common/driver.ts tools/copy-driver-definition.js",
    "copy-package-version": "node tools/copy-package-version.js",
    "prepublishOnly": "pnpm run copy-package-version"
  },
  "dependencies": {
    "graceful-fs": "4.2.11",
    "ncp": "2.0.0",
    "tmp": "0.2.1",
    "tree-kill": "1.2.2",
    "vscode-uri": "3.0.2"
  },
  "devDependencies": {
    "@types/graceful-fs": "4.1.9",
    "@types/ncp": "2.0.1",
    "@types/node": "22.x",
    "@types/tmp": "0.2.2",
    "cpx2": "3.0.0",
    "nodemon": "3.1.9",
    "playwright-core": "1.52.0"
  }
}
